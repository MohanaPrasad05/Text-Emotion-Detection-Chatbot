/* EMOTIONSENSE - FINAL PRODUCTION STYLESHEET
   Theme: High-Contrast Glassmorphism
   Target: Hackathon/Professional Dashboard
*/

:root {
    --bg-color: #0b0f1a;
    --card-bg: rgba(22, 30, 46, 0.85); /* Slightly more opaque for better text contrast */
    --accent: #38bdf8;
    --text-main: #ffffff; /* Pure white for primary data */
    --text-dim: #cbd5e1;  /* Bright light gray for labels - ensures visibility */
    --neg-color: #f43f5e; /* Vibrant Red */
    --neu-color: #eab308; /* Vibrant Yellow */
    --pos-color: #10b981; /* Vibrant Green */
}

/* Global Reset & Smooth Animations */
* { 
    box-sizing: border-box; 
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
}

body {
    background-color: var(--bg-color);
    background-image: radial-gradient(circle at top right, #1e293b, #0b0f1a);
    color: var(--text-main);
    font-family: 'Inter', sans-serif;
    margin: 0; 
    display: flex; 
    justify-content: center; 
    align-items: center; 
    min-height: 100vh;
}

/* Main Application Container */
.glass-container {
    width: 95%; 
    max-width: 800px;
    background: var(--card-bg);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 28px; 
    padding: 35px;
    box-shadow: 0 40px 100px -20px rgba(0, 0, 0, 0.7);
}

/* Branding & Header */
header { text-align: center; margin-bottom: 30px; }
.logo-area i { font-size: 2.2rem; color: var(--accent); margin-right: 12px; }
h1 { display: inline; font-size: 2.2rem; letter-spacing: -1px; }
h1 span { color: var(--accent); font-weight: 300; }
.tagline { color: var(--text-dim); text-align: center; margin-top: 5px; font-size: 1rem; }

/* Dashboard Cards */
.card { 
    background: rgba(255, 255, 255, 0.03); 
    border-radius: 20px; 
    padding: 25px; 
    border: 1px solid rgba(255, 255, 255, 0.05); 
    margin-bottom: 20px; 
}

/* UPDATED: Large & Bold Section Headings (Neural Input, Intensity Scale, etc.) */
.card-header { 
    display: flex; 
    align-items: center; 
    gap: 12px; 
    margin-bottom: 20px; 
    color: var(--accent); 
}

.card-header h3 {
    font-size: 1.4rem; /* Significantly larger */
    font-weight: 800;  /* Extra bold */
    text-transform: uppercase; 
    letter-spacing: 1.5px;
    margin: 0;
}

.card-header i {
    font-size: 1.5rem; /* Scales icon with text */
}

/* Input Styling */
textarea {
    width: 100%; 
    height: 120px; 
    background: rgba(0, 0, 0, 0.4); 
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 15px; 
    color: #fff; 
    padding: 18px; 
    font-size: 1.1rem; 
    resize: none;
}

/* UPDATED: Large & Bold 'Run Analysis' Button */
button {
    width: 100%; 
    margin-top: 15px; 
    padding: 20px; /* Increased padding */
    background: var(--accent); 
    color: #000;
    border: none; 
    border-radius: 15px; 
    font-size: 1.25rem; /* Larger text */
    font-weight: 900;    /* Maximum boldness */
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer; 
    display: flex; 
    justify-content: center; 
    align-items: center;
    gap: 12px;
}

button:hover {
    background: #7dd3fc;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(56, 189, 248, 0.3);
}

/* Statistics Grid - Labels and Data Visibility */
.stats-grid { 
    display: grid; 
    grid-template-columns: repeat(3, 1fr); 
    gap: 15px; 
    margin-bottom: 25px; 
}

.stat-card { 
    text-align: center; 
    background: rgba(255, 255, 255, 0.05);
    padding: 20px 10px;
    border-radius: 16px;
}

.stat-card label { 
    font-size: 0.75rem; 
    color: var(--text-dim); 
    text-transform: uppercase; 
    font-weight: 700;
    letter-spacing: 1.2px;
    display: block;
    margin-bottom: 10px;
}

.stat-card h2 { 
    margin: 0; 
    color: #ffffff; 
    font-size: 1.3rem; /* Increased size for results */
    font-weight: 800;
    white-space: nowrap; 
    text-shadow: 0 0 10px rgba(56, 189, 248, 0.3);
}

/* Spectrum Visualizer - Negative (Left) to Positive (Right) */
.spectrum-wrapper { position: relative; padding: 15px 0; }

.label-row { 
    display: flex; 
    justify-content: space-between; 
    font-size: 0.9rem; /* Slightly larger labels */
    font-weight: 800; 
    margin-bottom: 15px; 
}

.label-neg { color: var(--neg-color); }
.label-neu { color: var(--neu-color); }
.label-pos { color: var(--pos-color); }

.spectrum-bar { 
    height: 14px; 
    width: 100%; 
    background: linear-gradient(90deg, var(--neg-color) 0%, var(--neu-color) 50%, var(--pos-color) 100%); 
    border-radius: 20px; 
    position: relative; 
}

/* Arrow/Indicator */
.indicator {
    position: absolute; 
    top: -10px; 
    left: 50%; 
    width: 5px; 
    height: 34px;
    background: #ffffff; 
    border-radius: 10px; 
    box-shadow: 0 0 20px rgba(255, 255, 255, 0.8);
    z-index: 10;
}

.pulse { 
    position: absolute; 
    top: -5px; 
    left: -18px; 
    width: 42px; 
    height: 42px; 
    background: rgba(255, 255, 255, 0.15); 
    border-radius: 50%; 
    animation: pulse-anim 2s infinite; 
}

/* Analysis Insight Text Styling */
#botReply {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--text-main);
}

/* Animations */
@keyframes pulse-anim { 
    0% { transform: scale(0.5); opacity: 1; } 
    100% { transform: scale(1.5); opacity: 0; } 
}

@keyframes spin { 100% { transform: rotate(360deg); } }

/* Utility Classes */
.hidden { display: none !important; }

.loading-overlay { text-align: center; padding: 30px; font-weight: 700; color: var(--accent); }

.spinner { 
    width: 45px; 
    height: 45px; 
    border: 5px solid rgba(56, 189, 248, 0.1); 
    border-top: 5px solid var(--accent); 
    border-radius: 50%; 
    animation: spin 1s linear infinite; 
    margin: 0 auto 15px; 
}

footer { 
    text-align: center; 
    margin-top: 25px; 
    font-size: 0.85rem; 
    color: var(--text-dim); 
    font-weight: 600;
}